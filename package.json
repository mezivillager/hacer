{
  "name": "hacer",
  "private": true,
  "version": "1.9.0",
  "description": "First-principles computing platform: build a computer from NAND gates up in an interactive 3D environment. Inspired by nand2tetris.",
  "license": "MIT",
  "author": "mezivillager",
  "repository": {
    "type": "git",
    "url": "https://github.com/mezivillager/hacer"
  },
  "bugs": {
    "url": "https://github.com/mezivillager/hacer/issues"
  },
  "packageManager": "pnpm@10.12.1",
  "homepage": "https://mezivillager.github.io/hacer/",
  "keywords": [
    "logic-gates",
    "simulator",
    "3d",
    "react",
    "education"
  ],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "lint": "pnpm run typecheck && eslint .",
    "lint:fix": "eslint . --fix",
    "lint:eslint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --grep @ui",
    "test:e2e:store": "playwright test --grep @store",
    "test:e2e:headed": "playwright test --headed --grep @ui --workers 1",
    "stryker": "stryker run",
    "stryker:changed": "bash scripts/stryker-changed.sh",
    "prepare": "husky install || true"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.4.2",
    "@types/three": "^0.181.0",
    "antd": "^6.0.1",
    "immer": "^11.1.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "three": "^0.183.2",
    "three-stdlib": "^2.36.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.57.0",
    "@rolldown/plugin-babel": "^0.2.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@stryker-mutator/core": "^9.4.0",
    "@stryker-mutator/vitest-runner": "^9.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.5.0",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "semantic-release": "^25.0.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "eslint"
    ]
  }
}
