{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "mutate is the set of files to test. Business logic only (.ts), no UI components (.tsx).",
  "packageManager": "npm",
  "mutate": [
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "!src/**/*.spec.ts",
    "!src/test/**",
    "!**/vite-env.d.ts"
  ],
  "reporters": [
    "html",
    "clear-text",
    "progress"
  ],
  "testRunner": "vitest",
  "coverageAnalysis": "perTest",
  "ignoreStatic": true,
  "buildCommand": "npm run build",
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 50
  }
}